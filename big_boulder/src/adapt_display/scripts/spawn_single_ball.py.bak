#!/usr/bin/env python3
"""
Spawn a single ball within the board/margin area.

The UI passes explicit world-space bounds in lidar-relative coordinates,
so that spawn regions always reflect where the lidar can actually see.

Parameters (all in meters, in lidar world space with lidar at origin):
  board_min_x, board_max_x, board_min_y, board_max_y  – inner board rectangle
  margin_min_x, margin_max_x, margin_min_y, margin_max_y – outer margin rectangle
  spawn_height – drop height above ground

80% of balls land within the board rect, 20% in the margin strip.
"""
import rclpy
from rclpy.node import Node
from gazebo_msgs.srv import SpawnEntity
import os
from ament_index_python.packages import get_package_share_directory
import random
import uuid


class SpawnSingleBallNode(Node):
    def __init__(self):
        super().__init__('spawn_single_ball')
        # Board bounds in lidar world space
        self.declare_parameter('board_min_x', -5.0)
        self.declare_parameter('board_max_x',  3.0)
        self.declare_parameter('board_min_y', -4.0)
        self.declare_parameter('board_max_y',  2.0)
        # Margin bounds in lidar world space
        self.declare_parameter('margin_min_x', -7.0)
        self.declare_parameter('margin_max_x',  5.0)
        self.declare_parameter('margin_min_y', -6.0)
        self.declare_parameter('margin_max_y',  4.0)
        self.declare_parameter('spawn_height', 2.0)

        self.client = self.create_client(SpawnEntity, '/spawn_entity')
        while not self.client.wait_for_service(timeout_sec=1.0):
            self.get_logger().info('service not available, waiting again...')

        self.spawn_ball()

    def _weighted_coord(self, bmin, bmax, mmin, mmax):
        """80% within board rect, 20% in margin strip on either side."""
        if random.random() < 0.8:
            return random.uniform(bmin, bmax)
        else:
            if random.random() < 0.5:
                return random.uniform(mmin, bmin)
            else:
                return random.uniform(bmax, mmax)

    def spawn_ball(self):
        bx0 = self.get_parameter('board_min_x').value
        bx1 = self.get_parameter('board_max_x').value
        by0 = self.get_parameter('board_min_y').value
        by1 = self.get_parameter('board_max_y').value
        mx0 = self.get_parameter('margin_min_x').value
        mx1 = self.get_parameter('margin_max_x').value
        my0 = self.get_parameter('margin_min_y').value
        my1 = self.get_parameter('margin_max_y').value
        height = self.get_parameter('spawn_height').value

        x = self._weighted_coord(bx0, bx1, mx0, mx1)
        y = self._weighted_coord(by0, by1, my0, my1)
        z = height

        request = SpawnEntity.Request()
        request.name = f"ball_{uuid.uuid4().hex[:8]}"

        urdf_file_path = os.path.join(
            get_package_share_directory('adapt_display'),
            'description',
            'ball.urdf'
        )
        with open(urdf_file_path, 'r') as f:
            request.xml = f.read()

        request.initial_pose.position.x = float(x)
        request.initial_pose.position.y = float(y)
        request.initial_pose.position.z = float(z)

        future = self.client.call_async(request)
        rclpy.spin_until_future_complete(self, future)
        if future.result() is not None:
            self.get_logger().info(f"Spawned {request.name} at X:{x:.3f} Y:{y:.3f} Z:{z:.2f}")
        else:
            self.get_logger().error("Failed to spawn ball")


def main(args=None):
    rclpy.init(args=args)
    node = SpawnSingleBallNode()
    node.destroy_node()
    rclpy.shutdown()


if __name__ == '__main__':
    main()
